{
  "expo": {
    "name": "Echo Stamp",
    "slug": "Echo-Stamp",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/images/echologo.png",
    "scheme": "echostamp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select and upload images and videos.",
        "NSCameraUsageDescription": "This app needs access to your camera to take photos and videos.",
        "NSMicrophoneUsageDescription": "This app needs access to your microphone for voice search."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "versionCode": 15,
      "package": "com.wilbert03.EchoStamp",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/echologowbg.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD9VXQz-DMfkpg3bxYyfN3XBN6lZOZLZZo"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/echologo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-secure-store",
      "expo-video",
      "expo-image-picker",
      "expo-location",
      "expo-notifications",
      "expo-mail-composer",
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Echo Stamp to save photos.",
          "savePhotosPermission": "Allow Echo Stamp to save photos."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "memoryMaximumSize": "4096m",
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "/libfbjni.so"
              ]
            }
          }
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow Echo Stamp to access the microphone for voice search.",
          "speechRecognitionPermission": "Allow Echo Stamp to use speech recognition for finding locations."
        }
      ],
      "expo-asset",
      "react-native-compressor"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df5006ae-ff44-4fc3-b592-4bb455733539"
      }
    }
  }
}
